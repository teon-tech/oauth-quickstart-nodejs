# Default values used when client_id, client_secret, or scope aren't passed
# as query params on /install. All three are optional here.
CLIENT_ID=
CLIENT_SECRET=
SCOPE=crm.objects.contacts.read

# Public URL of this app, used to build the OAuth redirect URI
# (${BASE_URL}/oauth-callback). Defaults to http://localhost:3000 if unset.
# Must exactly match a redirect URI configured in your HubSpot app's auth
# settings. Only needed when deploying somewhere other than localhost.
BASE_URL=

# Signs the session cookie. Optional locally (a random one is generated per
# process start), but set this explicitly on Vercel so the signing secret
# stays stable across invocations of the same warm serverless instance.
SESSION_SECRET=
